@{
    Layout = null;
    ViewBag.Title = "Tạo tài khoản | HealthCare+";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght%40400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/Content/css/font-awesome.min.css">
    <link rel="stylesheet" href="/Content/css/auth-page.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
</head>
<body>

@if (ViewBag.mess == "Success")
{
    <script>
        swal({ title: 'Đăng ký thành công!', text: 'Chào mừng bạn đến với HealthCare+', icon: 'success', button: 'Đăng nhập ngay' })
        .then(() => { window.location.href = '/Authencation/Login'; });
    </script>
}
@if (ViewBag.mess == "ErrorExist")
{
    <script>
        swal({ title: 'Email đã tồn tại!', text: 'Vui lòng sử dụng địa chỉ email khác.', icon: 'error', button: 'Thử lại' });
    </script>
}

<div class="hcp-auth-wrapper">

    <!-- ───── LEFT PANEL ───── -->
    <div class="hcp-auth-left" style="background-image: url('/Content/images/slides/v1-3.jpg');">
        <a href="/" class="hcp-auth-brand">
            <span class="brand-icon"><i class="fa fa-heartbeat"></i></span>
            HealthCare+
        </a>

        <div>
            <p class="hcp-auth-tagline">Tất cả trong một nền tảng</p>
            <h1 class="hcp-auth-heading">Tham gia cộng đồng<br>chăm sóc sức khỏe</h1>

            <ul class="hcp-auth-benefits">
                <li class="hcp-auth-benefit">
                    <div class="hcp-benefit-icon"><i class="fa fa-calendar-check-o"></i></div>
                    <div class="hcp-benefit-text">
                        <strong>Đặt lịch nhanh chóng</strong>
                        <span>Hẹn khám chuyên khoa chỉ trong vài cú chạm</span>
                    </div>
                </li>
                <li class="hcp-auth-benefit">
                    <div class="hcp-benefit-icon"><i class="fa fa-comments-o"></i></div>
                    <div class="hcp-benefit-text">
                        <strong>Tư vấn trực tuyến</strong>
                        <span>Chat hoặc video call với bác sĩ mọi lúc</span>
                    </div>
                </li>
                <li class="hcp-auth-benefit">
                    <div class="hcp-benefit-icon"><i class="fa fa-bell-o"></i></div>
                    <div class="hcp-benefit-text">
                        <strong>Nhắc nhở thông minh</strong>
                        <span>Không bao giờ bỏ lỡ lịch khám hay uống thuốc</span>
                    </div>
                </li>
                <li class="hcp-auth-benefit">
                    <div class="hcp-benefit-icon"><i class="fa fa-shield"></i></div>
                    <div class="hcp-benefit-text">
                        <strong>Bảo mật y tế</strong>
                        <span>Dữ liệu được mã hóa theo tiêu chuẩn quốc tế</span>
                    </div>
                </li>
            </ul>
        </div>

        <div class="hcp-auth-left-footer">
            <i class="fa fa-lock"></i>
            <span>Dữ liệu được bảo mật theo tiêu chuẩn y tế quốc tế</span>
        </div>
    </div>

    <!-- ───── RIGHT PANEL ───── -->
    <div class="hcp-auth-right">
        <div class="hcp-auth-form-box">
            <h2 class="hcp-form-title">Tạo tài khoản</h2>
            <p class="hcp-form-subtitle">Đã có tài khoản? <a href="/Authencation/Login">Đăng nhập</a></p>
            <form action="/Authencation/Singup" method="post">
                <!-- Họ và tên -->
                <label class="hcp-field-label">Họ và tên <span class="req">*</span></label>
                <div class="hcp-field-wrap">
                    <i class="fa fa-user hcp-field-icon-left"></i>
                    <input type="text" name="FullName" class="hcp-auth-input" placeholder="Nguyễn Văn A" required>
                </div>

                <!-- Email & Điện thoại -->
                <div class="hcp-field-row">
                    <div class="hcp-field-col">
                        <label class="hcp-field-label">Email <span class="req">*</span></label>
                        <div class="hcp-field-wrap">
                            <i class="fa fa-envelope-o hcp-field-icon-left"></i>
                            <input type="email" name="Email" class="hcp-auth-input" placeholder="email&#64;..." required>
                        </div>
                    </div>
                    <div class="hcp-field-col">
                        <label class="hcp-field-label">Điện thoại</label>
                        <div class="hcp-field-wrap">
                            <i class="fa fa-phone hcp-field-icon-left"></i>
                            <input type="text" name="PhoneNumber" class="hcp-auth-input" placeholder="09xx...">
                        </div>
                    </div>
                </div>

                <!-- Mật khẩu -->
                <label class="hcp-field-label">Mật khẩu <span class="req">*</span></label>
                <div class="hcp-field-wrap">
                    <i class="fa fa-lock hcp-field-icon-left"></i>
                    <input type="password" name="Password" id="signupPwd" class="hcp-auth-input" placeholder="Tạo mật khẩu" required>
                    <i class="fa fa-eye-slash hcp-field-icon-right" id="toggleSignupPwd"></i>
                </div>

                <!-- Xác nhận mật khẩu -->
                <label class="hcp-field-label">Xác nhận mật khẩu <span class="req">*</span></label>
                <div class="hcp-field-wrap">
                    <i class="fa fa-lock hcp-field-icon-left"></i>
                    <input type="password" name="ConfirmPassword" id="confirmPwd" class="hcp-auth-input" placeholder="Nhập lại mật khẩu" required>
                    <i class="fa fa-eye-slash hcp-field-icon-right" id="toggleConfirmPwd"></i>
                </div>

                <!-- Trường ẩn giữ nguyên dữ liệu -->
                <input type="hidden" name="Address" value="Chưa cập nhật">
                <input type="hidden" name="Gender" value="Chưa cập nhật">

                <!-- Terms -->
                <div class="hcp-terms-wrap">
                    <input type="checkbox" id="terms" required>
                    <label for="terms">
                        Tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a>
                    </label>
                </div>

                <button type="submit" class="hcp-auth-btn">
                    Tạo tài khoản <i class="fa fa-arrow-right"></i>
                </button>

                <div class="hcp-or-sep"><span>HOẶC</span></div>

                <a href="#" class="hcp-google-btn">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" width="20">
                    Đăng ký với Google
                </a>
            </form>
        </div>
    </div>
</div>

<script>
function togglePwd(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa fa-eye hcp-field-icon-right';
    } else {
        input.type = 'password';
        icon.className = 'fa fa-eye-slash hcp-field-icon-right';
    }
}
document.getElementById('toggleSignupPwd').addEventListener('click', () => togglePwd('signupPwd', 'toggleSignupPwd'));
document.getElementById('toggleConfirmPwd').addEventListener('click', () => togglePwd('confirmPwd', 'toggleConfirmPwd'));
</script>
</body>
</html>
