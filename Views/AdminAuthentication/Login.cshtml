@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Đăng nhập - Hệ thống quản trị</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
        .login-container {
            min-height: 100vh;
        }
        .bg-image {
            background-image: url('https://images.unsplash.com/photo-1551076805-e1869033e561?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .bg-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(13, 110, 253, 0.85) 0%, rgba(13, 202, 240, 0.75) 100%);
        }
        .login-panel {
            background: white;
            padding: 3rem;
            border-radius: 1.5rem;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        }
        .form-floating > label {
            color: #6c757d;
        }
        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
        }
        .btn-login {
            padding: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
        }
        .btn-doctor {
            padding: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            background-color: #e9ecef;
            color: #495057;
            transition: all 0.3s ease;
            border: none;
        }
        .btn-doctor:hover {
            background-color: #dee2e6;
            color: #212529;
            transform: translateY(-2px);
        }
        .logo-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            color: white;
            font-size: 2rem;
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.3);
        }
        .custom-hr {
            border-top: 1px solid #e9ecef;
            margin: 2rem 0;
        }
    </style>
</head>
<body>
    <div class="container-fluid login-container d-flex p-0">
        <div class="row w-100 m-0">
            <!-- Phần hình nền và giới thiệu bên trái -->
            <div class="col-lg-7 d-none d-lg-block bg-image p-0">
                <div class="bg-overlay d-flex flex-column justify-content-center p-5 text-white">
                    <div class="ms-5">
                        <h1 class="display-4 fw-bold mb-4">Hệ Thống<br>Quản Lý Y Tế</h1>
                        <p class="lead mb-4" style="max-width: 550px; line-height: 1.8; opacity: 0.9;">
                            Giải pháp toàn diện giúp tối ưu hóa quy trình quản lý lịch khám, theo dõi hồ sơ bệnh nhân và nâng cao chất lượng dịch vụ chăm sóc sức khỏe.
                        </p>
                        <div class="d-flex align-items-center mt-5">
                            <div class="me-5 text-center">
                                <h3 class="fw-bold mb-1">24/7</h3>
                                <small class="text-white-50 text-uppercase fw-bold">Hỗ trợ</small>
                            </div>
                            <div class="me-5 text-center">
                                <h3 class="fw-bold mb-1">99%</h3>
                                <small class="text-white-50 text-uppercase fw-bold">Hài lòng</small>
                            </div>
                            <div class="text-center">
                                <h3 class="fw-bold mb-1">Chuẩn y tế</h3>
                                <small class="text-white-50 text-uppercase fw-bold">Bảo mật dữ liệu</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Form đăng nhập bên phải -->
            <div class="col-lg-5 col-md-12 d-flex align-items-center justify-content-center p-4">
                <div class="w-100" style="max-width: 450px;">
                    <div class="login-panel">
                        <div class="text-center mb-4">
                            <div class="logo-icon">
                                <i class="fas fa-heartbeat"></i>
                            </div>
                            <h3 class="fw-bold text-dark mb-1">Chào mừng trở lại!</h3>
                            <p class="text-muted">Đăng nhập vào hệ thống quản trị</p>
                        </div>

                        <form action="/AdminAuthentication/Login" method="post">
                            @if (!string.IsNullOrEmpty(ViewBag.mess))
                            {
                                <div class="alert alert-danger d-flex align-items-center rounded-3 mb-4 border-0 shadow-sm" role="alert">
                                    <i class="fas fa-exclamation-circle me-2 fs-5"></i>
                                    <div>@ViewBag.mess</div>
                                </div>
                            }

                            <div class="form-floating mb-3">
                                <input class="form-control rounded-3" id="inputEmail" name="email" required type="email" placeholder="Email" />
                                <label for="inputEmail"><i class="far fa-envelope me-2 text-muted"></i>Email đăng nhập</label>
                            </div>
                            <div class="form-floating mb-3">
                                <input class="form-control rounded-3" id="inputPassword" name="password" required type="password" placeholder="Mật khẩu" />
                                <label for="inputPassword"><i class="fas fa-lock me-2 text-muted"></i>Mật khẩu</label>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" id="rememberMe">
                                    <label class="form-check-label text-muted small" for="rememberMe">
                                        Ghi nhớ đăng nhập
                                    </label>
                                </div>
                                <a href="#" class="text-primary text-decoration-none small fw-bold">Quên mật khẩu?</a>
                            </div>

                            <div class="d-grid gap-3">
                                <button class="btn btn-primary btn-login rounded-pill" type="submit">
                                    Đăng nhập <i class="fas fa-arrow-right ms-2"></i>
                                </button>
                                
                                <div class="position-relative text-center my-2">
                                    <hr class="custom-hr">
                                    <span class="position-absolute top-50 translate-middle-y px-3 bg-white text-muted small fw-bold" style="left: 50%;">HOẶC</span>
                                </div>
                                
                                <a href="/AdminAuthentication/LoginDoctor" class="btn btn-doctor rounded-pill text-center text-decoration-none">
                                    <i class="fas fa-user-md me-2"></i> Đăng nhập với tư cách Bác sĩ
                                </a>
                            </div>
                        </form>
                    </div>
                    <div class="text-center mt-4">
                        <p class="text-muted small fw-bold mb-0">&copy; @DateTime.Now.Year Hệ Thống Quản Lý Y Tế</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
