@{
    ViewBag.Title = "HealthCare+ | Đặt lịch khám nhanh, chăm sóc tận tâm";
}

<!-- Hero Section -->
<section class="hcp-home-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hcp-hero-content">
                    <div class="hcp-hero-tagline">
                        <i class="fa fa-hospital-o"></i> Chào mừng đến với Website Y Tế
                    </div>
                    <h1 class="hcp-hero-title">
                        Chăm Sóc Sức Khỏe<br>
                        <span>Chuyên Nghiệp & Tận Tâm</span>
                    </h1>
                    <p class="hcp-hero-desc">
                        Kết nối bạn với đội ngũ bác sĩ chuyên khoa hàng đầu. Đặt lịch khám dễ dàng, nhanh chóng và an toàn ngay tại nhà.
                    </p>
                    <div class="hcp-hero-cta">
                        <a href="/Doctor/Index" class="hcp-btn-solid" style="height: 50px; padding: 0 32px; font-size: 16px;">Đặt lịch khám</a>
                    </div>
                    <div class="hcp-hero-features">
                        <div class="hcp-hero-feature-item">
                            <i class="fa fa-check-circle"></i>
                            <span>Thông tin được bảo mật</span>
                        </div>
                        <div class="hcp-hero-feature-item">
                            <i class="fa fa-check-circle"></i>
                            <span>Bác sĩ được chứng nhận</span>
                        </div>
                        <div class="hcp-hero-feature-item">
                            <i class="fa fa-check-circle"></i>
                            <span>Hỗ trợ 24/7</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hcp-hero-image-wrap">
                    <img src="~/Content/images/slides/v1-3.jpg" alt="Doctor Hero">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Nav Entry Cards -->
<section class="hcp-nav-cards-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="hcp-nav-entry-card">
                    <div class="hcp-nav-card-icon">
                        <i class="fa fa-newspaper-o"></i>
                    </div>
                    <h3 class="hcp-nav-card-title">Tin tức</h3>
                    <p class="hcp-nav-card-desc">Cập nhật các tin tức mới nhất về sức khỏe, các mẹo hay để chăm sóc sức khỏe.</p>
                    <a href="/Post/Index" class="hcp-nav-card-btn">XEM THÊM</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="hcp-nav-entry-card">
                    <div class="hcp-nav-card-icon">
                        <i class="fa fa-stethoscope"></i>
                    </div>
                    <h3 class="hcp-nav-card-title">Dịch vụ</h3>
                    <p class="hcp-nav-card-desc">Cung cấp các dịch hiện đại, tiện nghi, an toàn sức khỏe và dễ dàng sử dụng.</p>
                    <a href="/Service/Index" class="hcp-nav-card-btn">XEM THÊM</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="hcp-nav-entry-card">
                    <div class="hcp-nav-card-icon">
                        <i class="fa fa-user-md"></i>
                    </div>
                    <h3 class="hcp-nav-card-title">Bác sĩ</h3>
                    <p class="hcp-nav-card-desc">Hội tụ các bác sĩ chuyên khoa, kĩ năng giỏi và thân thiện hòa đồng.</p>
                    <a href="/Doctor/Index" class="hcp-nav-card-btn">XEM THÊM</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Top Doctors -->
<section class="hcp-home-section">
    <div class="container">
        <div class="hcp-section-header">
            <h2 class="hcp-section-title">Top 3 bác sĩ</h2>
            <p class="hcp-section-subtitle">Đội ngũ chuyên gia tận tâm, giàu kinh nghiệm</p>
        </div>
        <div class="row">
            @foreach (var doctor in ViewBag.Doctor)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="hcp-doctor-card-home">
                        <div class="hcp-doctor-img-home">
                            <img src="~/Content/images/@doctor.Image" alt="@doctor.FullName">
                        </div>
                        <div class="hcp-doctor-info-home">
                            <h3 class="hcp-doctor-name-home">@doctor.FullName</h3>
                            <p class="hcp-doctor-spec-home">@doctor.Specialist</p>
                            <a href="/Doctor/Index" class="hcp-doctor-btn-home">Đặt Lịch</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Top Services -->
<section class="hcp-home-section">
    <div class="container">
        <div class="hcp-section-header">
            <h2 class="hcp-section-title">Top 3 Dịch vụ y tế</h2>
            <p class="hcp-section-subtitle">Dịch vụ đa dạng, tiêu chuẩn quốc tế</p>
        </div>
        <div class="row">
            @foreach (var service in ViewBag.Service)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="hcp-content-card">
                        <div class="hcp-content-img">
                            <img src="~/Content/images/@service.Image" alt="@service.Name">
                            <span class="hcp-content-badge">Dịch vụ</span>
                        </div>
                        <div class="hcp-content-body">
                            <div class="hcp-content-meta">
                                <img src="https://cdn2.iconfinder.com/data/icons/user-avatars-3/100/Doctor-512.png" class="hcp-author-avatar" alt="Admin">
                                <span class="hcp-meta-text">Quản trị viên • @String.Format("{0:dd/MM/yyyy}", service.Created)</span>
                            </div>
                            <h3 class="hcp-content-title">@service.Name</h3>
                            <div class="hcp-content-footer">
                                <a href="/Service/Detail/@service.IdService" class="hcp-link-more">Tìm hiểu thêm <i class="fa fa-long-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Latest News -->
<section class="hcp-home-section">
    <div class="container">
        <div class="hcp-section-header">
            <h2 class="hcp-section-title">Tin tức sức khỏe mới nhất</h2>
            <p class="hcp-section-subtitle">Cập nhật kiến thức y khoa bổ ích mỗi ngày</p>
        </div>
        <div class="row">
            @foreach (var post in ViewBag.Post)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="hcp-content-card">
                        <div class="hcp-content-img">
                            <img src="~/Content/images/@post.Image" alt="@post.Title">
                            <span class="hcp-content-badge">Tin tức</span>
                        </div>
                        <div class="hcp-content-body">
                            <div class="hcp-content-meta">
                                <img src="https://cdn2.iconfinder.com/data/icons/user-avatars-3/100/Doctor-512.png" class="hcp-author-avatar" alt="Admin">
                                <span class="hcp-meta-text">Quản trị viên • @String.Format("{0:dd/MM/yyyy}", post.Created)</span>
                            </div>
                            <h3 class="hcp-content-title">@post.Title</h3>
                            <div class="hcp-content-footer">
                                <a href="/Post/Detail/@post.IdPost" class="hcp-link-more">Xem thêm <i class="fa fa-long-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<script>
    $(document).ready(function () {
        $.ajax({
            type: "POST",
            contentType: "application/json",
            url: "/Home/RemoveNumberOnline",
            data: null,
            dataType: 'json',
            cache: false,
            success: function (t) {
                if (t.Status == true) {
                    console.log("success")
                } else {
                    console.log("error")
                }
            },
            error: function (e) {
                console.log("error")
            }
        });
    });
</script>
